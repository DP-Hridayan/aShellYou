<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AShellYou.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/animated_adb_splash_icon</item>
        <item name="windowSplashScreenAnimationDuration">1200</item>
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.AShellYou</item>
    </style>

    <style name="Theme.AShellYou" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>
</resources>