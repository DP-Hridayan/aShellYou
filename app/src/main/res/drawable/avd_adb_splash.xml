<?xml version="1.0" encoding="utf-8"?>
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:name="splash"
            android:width="320dp"
            android:height="320dp"
            android:viewportWidth="320"
            android:viewportHeight="320">

            <!--
                scaleme: root group for the scale-pop at impact.
                Everything lives inside here so the pop affects both
                the background circle and the icon content.
            -->
            <group
                android:name="scaleme"
                android:pivotX="160"
                android:pivotY="160"
                android:scaleX="1"
                android:scaleY="1">

                <!-- Static background circle (primaryContainer color) -->
                <group android:name="bg">
                    <path
                        android:name="circle"
                        android:fillColor="@color/splash_icon_background"
                        android:pathData="M 160 60 C 133.489 60 108.036 70.543 89.289 89.289 C 70.543 108.036 60 133.489 60 160 C 60 186.511 70.543 211.964 89.289 230.711 C 108.036 249.457 133.489 260 160 260 C 186.511 260 211.964 249.457 230.711 230.711 C 249.457 211.964 260 186.511 260 160 C 260 133.489 249.457 108.036 230.711 89.289 C 211.964 70.543 186.511 60 160 60 Z"
                        android:strokeWidth="1" />
                </group>

                <!-- Foreground content, clipped to the circle -->
                <group
                    android:name="fg"
                    android:pivotX="160"
                    android:pivotY="160">

                    <!-- Circle clip-path: sliding head/body are masked outside this -->
                    <clip-path
                        android:name="mask"
                        android:pathData="M 160 60 C 133.489 60 108.036 70.543 89.289 89.289 C 70.543 108.036 60 133.489 60 160 C 60 186.511 70.543 211.964 89.289 230.711 C 108.036 249.457 133.489 260 160 260 C 186.511 260 211.964 249.457 230.711 230.711 C 249.457 211.964 260 186.511 260 160 C 260 133.489 249.457 108.036 230.711 89.289 C 211.964 70.543 186.511 60 160 60 Z" />

                    <!--
                        Anonymous positioning group: maps the ADB icon's native 48x48
                        coordinate space into the 320x320 viewport, centered at (160,160).
                        scale=3.26, translate=(81.76, 80.13) places the icon center at (160,160)
                        and scales it so the icon fits within the 100-unit radius clip circle.
                    -->
                    <group
                        android:scaleX="3.26"
                        android:scaleY="3.26"
                        android:translateX="81.76"
                        android:translateY="80.13">

                        <!--
                            head_group: starts at translateY=-50 (163 visual units above
                            its rest position — fully off the top of the canvas).
                        -->
                        <group
                            android:name="head_group"
                            android:pivotX="24"
                            android:pivotY="22"
                            android:rotation="0"
                            android:translateY="-50">

                            <path
                                android:fillColor="@color/ic_launcher_foreground_color"
                                android:pathData="M10 21.95v-2q0-3.6 1.65-6.55Q13.3 10.45 16 8.55L12.25 4.8l1.8-1.8 4.25 4.2q1.25-0.6 2.725-0.925Q22.5 5.95 24 5.95t2.975 0.325Q28.45 6.6 29.75 7.2l4.2-4.2 1.8 1.8L32 8.55q2.7 1.9 4.35 4.85Q38 16.35 38 19.95v2z" />

                            <group
                                android:name="right_eye_group"
                                android:pivotX="30"
                                android:pivotY="15.95"
                                android:scaleY="1">
                                <path
                                    android:fillColor="@color/splash_icon_background"
                                    android:pathData="M30 17.95q0.85 0 1.425-0.575Q32 16.8 32 15.95q0-0.85-0.575-1.425Q30.85 13.95 30 13.95q-0.85 0-1.425 0.575Q28 15.1 28 15.95q0 0.85 0.575 1.425Q29.15 17.95 30 17.95z" />
                            </group>

                            <group
                                android:name="left_eye_group"
                                android:pivotX="18"
                                android:pivotY="15.95"
                                android:scaleY="1">
                                <path
                                    android:fillColor="@color/splash_icon_background"
                                    android:pathData="M18 17.95q0.85 0 1.425-0.575Q20 16.8 20 15.95q0-0.85-0.575-1.425Q18.85 13.95 18 13.95q-0.85 0-1.425 0.575Q16 15.1 16 15.95q0 0.85 0.575 1.425Q17.15 17.95 18 17.95z" />
                            </group>
                        </group>

                        <!--
                            body_group: starts at translateY=+50 (163 visual units below
                            its rest position — fully off the bottom of the canvas).
                        -->
                        <group
                            android:name="body_group"
                            android:pivotX="24"
                            android:pivotY="24"
                            android:rotation="0"
                            android:translateY="50">
                            <path
                                android:fillColor="@color/ic_launcher_foreground_color"
                                android:pathData="M24 46q-5.85 0-9.925-4.075Q10 37.85 10 32v-8.05h28V32q0 5.85-4.075 9.925Q29.85 46 24 46z" />
                        </group>

                    </group>
                </group>
            </group>
        </vector>
    </aapt:attr>

    <!-- ═══════════════════════════════════════════════
         ANIMATION TARGETS — all inline via aapt:attr
         Total timeline: ~1100ms
         ═══════════════════════════════════════════════ -->

    <!-- scaleme: scale pop at collision (350ms), settle with overshoot (950ms) -->
    <target android:name="scaleme">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:startOffset="350"
                    android:duration="600">
                    <propertyValuesHolder android:propertyName="scaleX">
                        <keyframe android:fraction="0" android:value="1.0" android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.25"
                            android:value="1.15"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/accelerate_cubic" />
                        <keyframe
                            android:fraction="1.0"
                            android:value="1.0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/overshoot" />
                    </propertyValuesHolder>
                </objectAnimator>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="350"
                    android:duration="600">
                    <propertyValuesHolder android:propertyName="scaleY">
                        <keyframe android:fraction="0" android:value="1.0" android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.25"
                            android:value="1.15"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/accelerate_cubic" />
                        <keyframe
                            android:fraction="1.0"
                            android:value="1.0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/overshoot" />
                    </propertyValuesHolder>
                </objectAnimator>
            </set>
        </aapt:attr>
    </target>

    <!-- head_group: slide from top (0–400ms) → impact twist +12° → spring to 0° (400–900ms) -->
    <target android:name="head_group">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:propertyName="translateY"
                    android:valueFrom="-50"
                    android:valueTo="0"
                    android:valueType="floatType"
                    android:duration="400"
                    android:interpolator="@android:interpolator/accelerate_cubic" />
                <objectAnimator
                    android:propertyName="rotation"
                    android:startOffset="400"
                    android:duration="500">
                    <propertyValuesHolder android:propertyName="rotation">
                        <keyframe android:fraction="0" android:value="0" android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.3"
                            android:value="12"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/accelerate_cubic" />
                        <keyframe
                            android:fraction="1.0"
                            android:value="0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/overshoot" />
                    </propertyValuesHolder>
                </objectAnimator>
            </set>
        </aapt:attr>
    </target>

    <!-- body_group: slide from bottom (0–400ms) → opposing twist −8° → spring to 0° (400–900ms) -->
    <target android:name="body_group">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:propertyName="translateY"
                    android:valueFrom="50"
                    android:valueTo="0"
                    android:valueType="floatType"
                    android:duration="400"
                    android:interpolator="@android:interpolator/accelerate_cubic" />
                <objectAnimator
                    android:propertyName="rotation"
                    android:startOffset="400"
                    android:duration="500">
                    <propertyValuesHolder android:propertyName="rotation">
                        <keyframe android:fraction="0" android:value="0" android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.3"
                            android:value="-8"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/accelerate_cubic" />
                        <keyframe
                            android:fraction="1.0"
                            android:value="0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/overshoot" />
                    </propertyValuesHolder>
                </objectAnimator>
            </set>
        </aapt:attr>
    </target>

    <!-- right eye blink: scaleY 1→0→1 (900–1100ms) -->
    <target android:name="right_eye_group">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="900"
                    android:duration="200">
                    <propertyValuesHolder android:propertyName="scaleY">
                        <keyframe android:fraction="0" android:value="1.0" android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.5"
                            android:value="0.0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/accelerate_quad" />
                        <keyframe
                            android:fraction="1.0"
                            android:value="1.0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/decelerate_quad" />
                    </propertyValuesHolder>
                </objectAnimator>
            </set>
        </aapt:attr>
    </target>

    <!-- left eye blink: same timing as right -->
    <target android:name="left_eye_group">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="900"
                    android:duration="200">
                    <propertyValuesHolder android:propertyName="scaleY">
                        <keyframe android:fraction="0" android:value="1.0" android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.5"
                            android:value="0.0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/accelerate_quad" />
                        <keyframe
                            android:fraction="1.0"
                            android:value="1.0"
                            android:valueType="floatType"
                            android:interpolator="@android:interpolator/decelerate_quad" />
                    </propertyValuesHolder>
                </objectAnimator>
            </set>
        </aapt:attr>
    </target>

</animated-vector>
