                            android:value="1.0"
                            android:valueType="floatType" />
                        <keyframe
                            android:fraction="0.25"
                            android:interpolator="@android:interpolator/accelerate_cubic"
                            android:value="1.15"
                            android:valueType="floatType" />
                        <keyframe
