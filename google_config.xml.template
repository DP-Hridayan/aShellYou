<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Copy this file to app/src/main/res/values/google_config.xml 
    and replace the placeholder with your Web Client ID from Google Cloud Console.
    
    To create one: Cloud Console → Credentials → Create OAuth Client ID → Web application → Create
    The client_secret is NOT needed on Android.
-->
<resources>
    <string name="google_web_client_id" translatable="false">YOUR_WEB_CLIENT_ID_HERE</string>
</resources>
